generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AuthProvider {
  GOOGLE
  EMAIL
}

enum IncomeCategory {
  SALARY
  FREELANCE
  DIVIDENDS
  RENTAL
  SIDE_HUSTLE
  OTHER
}

enum Currency {
  RWF
  USD
}

enum SavingTransactionType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
}

enum MoneyMovementType {
  SAVING_WITHDRAWAL
  MANUAL_ADJUSTMENT
}

enum TodoPriority {
  TOP_PRIORITY
  PRIORITY
  NOT_PRIORITY
}

enum TodoFrequency {
  ONCE
  WEEKLY
  MONTHLY
  YEARLY
}

enum PartnershipStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum ExpenseCategory {
  FOOD_DINING
  TRANSPORT
  HOUSING
  LOAN
  UTILITIES
  HEALTHCARE
  EDUCATION
  ENTERTAINMENT
  SHOPPING
  PERSONAL_CARE
  TRAVEL
  SAVINGS
  OTHER
}

enum ExpensePaymentMethod {
  CASH
  BANK
  MOBILE_MONEY
  CARD
  OTHER
}

enum ExpenseMobileMoneyChannel {
  MERCHANT_CODE
  P2P_TRANSFER
}

enum ExpenseMobileMoneyProvider {
  MTN_RWANDA
  OTHER
}

enum ExpenseMobileMoneyNetwork {
  ON_NET
  OFF_NET
}

// ─────────────────────────────────────────────────────────────
// Core user models
// ─────────────────────────────────────────────────────────────

model User {
  id                String              @id @default(uuid()) @db.Uuid
  email             String              @unique
  firstName         String?
  lastName          String?
  fullName          String?
  avatarUrl         String?
  isEmailVerified   Boolean             @default(false)
  status            UserStatus          @default(ACTIVE)
  lastLoginAt       DateTime?
  accountDeletionRequestedAt DateTime?
  accountDeletionScheduledFor DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  authIdentities    AuthIdentity[]
  sessions          Session[]
  incomes           Income[]
  todos             Todo[]
  expenses          Expense[]
  loans             Loan[]
  savings           Saving[]
  savingTransactions SavingTransaction[]
  moneyMovements    MoneyMovement[]
  loginOtpChallenge   LoginOtpChallenge?
  sentPartnership     Partnership?       @relation("PartnershipOwner")
  receivedPartnership Partnership?       @relation("PartnershipPartner")

  @@index([status])
  @@index([deletedAt])
}

model AuthIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  provider       AuthProvider
  providerUserId String
  providerEmail  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider, providerEmail])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ─────────────────────────────────────────────────────────────
// Email OTP: login challenge for existing verified users
// One active challenge per user at a time (unique userId).
// ─────────────────────────────────────────────────────────────

model LoginOtpChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  otpHash      String
  otpExpiresAt DateTime
  attemptCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([otpExpiresAt])
}

// ─────────────────────────────────────────────────────────────
// Email OTP: pending registration for first-time users
// Upserted on each request — one record per email at a time.
// Deleted and replaced by a full User row on successful verify.
// ─────────────────────────────────────────────────────────────

model PendingUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  otpHash      String
  otpExpiresAt DateTime
  attemptCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([otpExpiresAt])
}

model Income {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  label     String
  amount    Decimal        @db.Decimal(15, 2)
  currency  Currency       @default(RWF)
  amountRwf Decimal        @default(0) @db.Decimal(15, 2)
  category  IncomeCategory
  date      DateTime
  received  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingTransactionSources SavingTransactionIncomeSource[]

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, category])
  @@index([userId, received])
  @@index([userId, currency])
}

model Expense {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  label     String
  amount    Decimal         @db.Decimal(15, 2)
  currency  Currency        @default(RWF)
  amountRwf Decimal         @default(0) @db.Decimal(15, 2)
  feeAmount Decimal         @default(0) @db.Decimal(15, 2)
  feeAmountRwf Decimal      @default(0) @db.Decimal(15, 2)
  totalAmountRwf Decimal    @default(0) @db.Decimal(15, 2)
  paymentMethod ExpensePaymentMethod @default(CASH)
  mobileMoneyChannel ExpenseMobileMoneyChannel?
  mobileMoneyProvider ExpenseMobileMoneyProvider?
  mobileMoneyNetwork ExpenseMobileMoneyNetwork?
  category  ExpenseCategory
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, category])
  @@index([userId, paymentMethod])
  @@index([userId, currency])
}

model MobileMoneyTariff {
  id         String                    @id @default(uuid()) @db.Uuid
  provider   ExpenseMobileMoneyProvider
  channel    ExpenseMobileMoneyChannel
  network    ExpenseMobileMoneyNetwork?
  minAmount  Decimal                   @db.Decimal(15, 2)
  maxAmount  Decimal                   @db.Decimal(15, 2)
  feeAmount  Decimal                   @db.Decimal(15, 2)
  active     Boolean                   @default(true)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@index([provider, channel, network, active])
  @@index([active, minAmount, maxAmount])
}

model Loan {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  label     String
  amount    Decimal  @db.Decimal(15, 2)
  date      DateTime
  note      String?
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, paid])
}

model Saving {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  label           String
  amount          Decimal  @db.Decimal(15, 2)
  currency        Currency @default(RWF)
  amountRwf       Decimal  @default(0) @db.Decimal(15, 2)
  targetAmount    Decimal? @db.Decimal(15, 2)
  targetCurrency  Currency?
  targetAmountRwf Decimal? @db.Decimal(15, 2)
  startDate       DateTime? @db.Date
  endDate         DateTime? @db.Date
  date            DateTime
  note            String?
  stillHave       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions SavingTransaction[]

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, stillHave])
  @@index([userId, currency])
  @@index([userId, startDate])
  @@index([userId, endDate])
}

model SavingTransaction {
  id                    String                @id @default(uuid()) @db.Uuid
  savingId              String                @db.Uuid
  userId                String                @db.Uuid
  type                  SavingTransactionType
  amount                Decimal               @db.Decimal(15, 2)
  currency              Currency              @default(RWF)
  amountRwf             Decimal               @db.Decimal(15, 2)
  date                  DateTime
  note                  String?
  reversalOfTransactionId String?             @unique @db.Uuid
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  saving                Saving                @relation(fields: [savingId], references: [id], onDelete: Cascade)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSources         SavingTransactionIncomeSource[]
  moneyMovement         MoneyMovement?
  reversalOfTransaction SavingTransaction?    @relation("SavingTransactionReversal", fields: [reversalOfTransactionId], references: [id], onDelete: SetNull)
  reversedByTransaction SavingTransaction?    @relation("SavingTransactionReversal")

  @@index([savingId])
  @@index([userId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
  @@index([reversalOfTransactionId])
}

model SavingTransactionIncomeSource {
  id                  String            @id @default(uuid()) @db.Uuid
  savingTransactionId String            @db.Uuid
  incomeId            String            @db.Uuid
  amount              Decimal           @db.Decimal(15, 2)
  currency            Currency          @default(RWF)
  amountRwf           Decimal           @db.Decimal(15, 2)
  savingTransaction   SavingTransaction @relation(fields: [savingTransactionId], references: [id], onDelete: Cascade)
  income              Income            @relation(fields: [incomeId], references: [id], onDelete: Restrict)

  @@unique([savingTransactionId, incomeId])
  @@index([savingTransactionId])
  @@index([incomeId])
}

model MoneyMovement {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @db.Uuid
  type                MoneyMovementType
  amount              Decimal            @db.Decimal(15, 2)
  currency            Currency           @default(RWF)
  amountRwf           Decimal            @db.Decimal(15, 2)
  date                DateTime
  note                String?
  savingTransactionId String?            @unique @db.Uuid
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingTransaction   SavingTransaction? @relation(fields: [savingTransactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
}

model AppSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id                     String        @id @default(uuid()) @db.Uuid
  userId                 String        @db.Uuid
  name                   String
  price                  Decimal       @db.Decimal(15, 2)
  priority               TodoPriority
  done                   Boolean       @default(false)
  frequency              TodoFrequency @default(ONCE)
  startDate              DateTime?     @db.Date
  endDate                DateTime?     @db.Date
  frequencyDays          Int[]         @default([])
  occurrenceDates        String[]      @default([])
  recordedOccurrenceDates String[]     @default([])
  remainingAmount        Decimal?      @db.Decimal(15, 2)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  deletedAt              DateTime?
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images                 TodoImage[]

  @@index([userId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([userId, priority])
  @@index([userId, done])
  @@index([userId, frequency])
}

model Partnership {
  id           String            @id @default(uuid()) @db.Uuid
  ownerId      String            @unique @db.Uuid
  partnerId    String?           @unique @db.Uuid
  inviteeEmail String
  tokenHash    String            @unique
  status       PartnershipStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  owner        User              @relation("PartnershipOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  partner      User?             @relation("PartnershipPartner", fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([tokenHash])
  @@index([inviteeEmail])
}

model TodoImage {
  id        String   @id @default(uuid()) @db.Uuid
  todoId    String   @db.Uuid
  publicId  String   @unique
  imageUrl  String
  width     Int
  height    Int
  bytes     Int
  format    String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId])
  @@index([deletedAt])
  @@index([todoId, isPrimary])
}
