generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AuthProvider {
  GOOGLE
  EMAIL
}

enum IncomeCategory {
  SALARY
  FREELANCE
  DIVIDENDS
  RENTAL
  SIDE_HUSTLE
  OTHER
}

enum TodoPriority {
  TOP_PRIORITY
  PRIORITY
  NOT_PRIORITY
}

enum ExpenseCategory {
  FOOD_DINING
  TRANSPORT
  HOUSING
  LOAN
  UTILITIES
  HEALTHCARE
  EDUCATION
  ENTERTAINMENT
  SHOPPING
  PERSONAL_CARE
  TRAVEL
  SAVINGS
  OTHER
}

// ─────────────────────────────────────────────────────────────
// Core user models
// ─────────────────────────────────────────────────────────────

model User {
  id                String              @id @default(uuid()) @db.Uuid
  email             String              @unique
  firstName         String?
  lastName          String?
  fullName          String?
  avatarUrl         String?
  isEmailVerified   Boolean             @default(false)
  status            UserStatus          @default(ACTIVE)
  lastLoginAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  authIdentities    AuthIdentity[]
  sessions          Session[]
  incomes           Income[]
  todos             Todo[]
  expenses          Expense[]
  loans             Loan[]
  loginOtpChallenge LoginOtpChallenge?

  @@index([status])
  @@index([deletedAt])
}

model AuthIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  provider       AuthProvider
  providerUserId String
  providerEmail  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider, providerEmail])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ─────────────────────────────────────────────────────────────
// Email OTP: login challenge for existing verified users
// One active challenge per user at a time (unique userId).
// ─────────────────────────────────────────────────────────────

model LoginOtpChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  otpHash      String
  otpExpiresAt DateTime
  attemptCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([otpExpiresAt])
}

// ─────────────────────────────────────────────────────────────
// Email OTP: pending registration for first-time users
// Upserted on each request — one record per email at a time.
// Deleted and replaced by a full User row on successful verify.
// ─────────────────────────────────────────────────────────────

model PendingUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  otpHash      String
  otpExpiresAt DateTime
  attemptCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([otpExpiresAt])
}

model Income {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  label     String
  amount    Decimal        @db.Decimal(15, 2)
  category  IncomeCategory
  date      DateTime
  received  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, category])
  @@index([userId, received])
}

model Expense {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  label     String
  amount    Decimal         @db.Decimal(15, 2)
  category  ExpenseCategory
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, category])
}

model Loan {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  label     String
  amount    Decimal  @db.Decimal(15, 2)
  date      DateTime
  note      String?
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@index([date])
  @@index([userId, paid])
}

model Todo {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  name      String
  price     Decimal      @db.Decimal(15, 2)
  priority  TodoPriority
  done      Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    TodoImage[]

  @@index([userId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([userId, priority])
  @@index([userId, done])
}

model TodoImage {
  id        String   @id @default(uuid()) @db.Uuid
  todoId    String   @db.Uuid
  publicId  String   @unique
  imageUrl  String
  width     Int
  height    Int
  bytes     Int
  format    String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId])
  @@index([deletedAt])
  @@index([todoId, isPrimary])
}
